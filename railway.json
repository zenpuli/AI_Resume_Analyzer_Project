{
  "$schema": "https://railway.app/railway.schema.json",
  "build": {
    "rootDirectory": "/backend",
    "watchPatterns": ["backend/**"]
  },
  "deploy": {
    "startCommand": "uvicorn app:app --host 0.0.0.0 --port $PORT",
    "restartPolicyType": "ON_FAILURE",
    "restartPolicyMaxRetries": 10
  }
}